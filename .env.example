# Environment Variables for Endless Tales
# Copy this file to .env.local and fill in your API keys

# Server-side API Keys (used by /api/ai-proxy when users haven't provided their own keys)
# These keys are kept secure on the server and never exposed to the client

# Gemini (Google AI)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Claude (Anthropic)
CLAUDE_API_KEY=your_claude_api_key_here

# DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# OpenRouter (optional - for accessing multiple models through one API)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# App URL (used by OpenRouter for referrals)
NEXT_PUBLIC_APP_URL=http://localhost:9002
